rules_version = '2';

// ================================================================
// Reglas de seguridad de Firestore — JC Finanzas (Jóvenes Central)
//
// Este archivo es la COPIA MAESTRA de las reglas. Para que tengan
// efecto hay que pegarlas en:
//   Firebase console → Firestore Database → pestaña "Reglas" → Publicar
//
// Estas reglas se evalúan en los servidores de Google: aunque
// alguien modifique la app en su navegador, no puede saltárselas.
// ================================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // ============================================================
    // LISTA DE CORREOS AUTORIZADOS
    // Para dar o quitar acceso a una persona, editá esta lista
    // (un correo por línea, entre comillas, separados por comas)
    // y presioná "Publicar" en la consola.
    // ============================================================
    function esAutorizado() {
      return request.auth != null
        && request.auth.token.email_verified == true
        && request.auth.token.email in [
             'kevindp2008@gmail.com'
           ];
    }

    // Validación de datos: tipos correctos, montos positivos,
    // campos requeridos y ningún campo extra.
    function esMovimientoValido(d) {
      return d.monto is number && d.monto > 0 && d.monto <= 1000000000
        && d.fecha is string && d.fecha.matches('^[0-9]{4}-[0-9]{2}-[0-9]{2}$')
        && d.descripcion is string && d.descripcion.size() <= 500
        && d.creadoPor is string
        && (
          // Ingresos y gastos (con sobre opcional)
          (
            d.tipo in ['ingreso', 'gasto']
            && d.keys().hasAll(['tipo', 'monto', 'fecha', 'categoria', 'descripcion', 'metodo', 'creadoPor', 'creadoEn'])
            && d.keys().hasOnly(['tipo', 'monto', 'fecha', 'categoria', 'descripcion', 'metodo', 'sobre', 'creadoPor', 'creadoEn'])
            && d.categoria is string && d.categoria.size() > 0 && d.categoria.size() <= 50
            && d.metodo in ['efectivo', 'depositado']
            && (!('sobre' in d) || (d.sobre is string && d.sobre.size() <= 50))
          )
          ||
          // Traslados entre efectivo y depositado
          (
            d.tipo == 'traslado'
            && d.keys().hasAll(['tipo', 'monto', 'fecha', 'descripcion', 'direccion', 'creadoPor', 'creadoEn'])
            && d.keys().hasOnly(['tipo', 'monto', 'fecha', 'descripcion', 'direccion', 'creadoPor', 'creadoEn'])
            && d.direccion in ['efectivo-a-depositado', 'depositado-a-efectivo']
          )
          ||
          // Asignaciones entre sobres (no cambian el saldo total)
          (
            d.tipo == 'asignacion'
            && d.keys().hasAll(['tipo', 'monto', 'fecha', 'descripcion', 'sobreOrigen', 'sobreDestino', 'creadoPor', 'creadoEn'])
            && d.keys().hasOnly(['tipo', 'monto', 'fecha', 'descripcion', 'sobreOrigen', 'sobreDestino', 'creadoPor', 'creadoEn'])
            && d.sobreOrigen is string && d.sobreOrigen.size() <= 50
            && d.sobreDestino is string && d.sobreDestino.size() <= 50
            && d.sobreOrigen != d.sobreDestino
          )
        );
    }

    match /movimientos/{id} {
      allow read: if esAutorizado();

      allow create: if esAutorizado()
        && esMovimientoValido(request.resource.data)
        && request.resource.data.creadoPor == request.auth.token.email
        && request.resource.data.creadoEn == request.time;

      // Al editar no se permite cambiar quién lo creó ni cuándo.
      allow update: if esAutorizado()
        && esMovimientoValido(request.resource.data)
        && request.resource.data.creadoPor == resource.data.creadoPor
        && request.resource.data.creadoEn == resource.data.creadoEn;

      allow delete: if esAutorizado();
    }

    // Listas de configuración: categorías y sobres.
    match /config/{docId} {
      allow read: if esAutorizado();
      allow write: if esAutorizado()
        && docId in ['categorias', 'sobres']
        && request.resource.data.keys().hasOnly(['lista'])
        && request.resource.data.lista is list
        && request.resource.data.lista.size() <= 30;
    }

    // Cualquier otra ruta: prohibido para todo el mundo.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
